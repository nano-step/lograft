{
  "name": "lograft",
  "version": "0.1.0-beta.1",
  "description": "MCP server that rafts logs, code, and tickets into investigation reports.",
  "type": "module",
  "bin": {
    "lograft": "./dist/bin/lograft.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=20.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nano-step/lograft.git"
  },
  "bugs": {
    "url": "https://github.com/nano-step/lograft/issues"
  },
  "homepage": "https://github.com/nano-step/lograft#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "kql",
    "azure",
    "log-analysis",
    "investigation",
    "post-mortem",
    "logs"
  ],
  "author": "Hoài Nhớ <nhoxtvt@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/hoainho",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.0"
  }
}
